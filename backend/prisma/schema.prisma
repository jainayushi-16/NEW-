// ==================================================
// PHASE 6 — Field Force
// ==================================================

model Attendance {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  userId         String           @db.Uuid
  date           DateTime         @db.Date
  checkInAt      DateTime?
  checkOutAt     DateTime?
  checkInLoc     Json?
  checkOutLoc    Json?
  status         AttendanceStatus @default(ABSENT)
  durationMins   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([organizationId, date])
}

model Visit {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @db.Uuid
  userId         String      @db.Uuid
  leadId         String?     @db.Uuid
  title          String
  type           VisitType   @default(MEETING)
  status         VisitStatus @default(PLANNED)
  scheduledAt    DateTime
  completedAt    DateTime?
  location       Json?
  notes          String?
  photoUrl       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([organizationId, userId])
  @@index([leadId])
}

model Expense {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  userId         String          @db.Uuid
  approvedById   String?         @db.Uuid
  amount         Float
  category       ExpenseCategory
  date           DateTime        @db.Date
  status         ExpenseStatus   @default(PENDING)
  receiptUrl     String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy   User?        @relation("ExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([organizationId, userId])
}

model DailyActivityReport {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  date           DateTime  @db.Date
  totalVisits    Int       @default(0)
  totalOrders    Int       @default(0)
  summary        String?
  status         DarStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HALFDAY
}

enum VisitType {
  COLD_CALL
  FOLLOW_UP
  MEETING
  DEMO
}

enum VisitStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  TRAVEL
  MEALS
  ACCOMMODATION
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DarStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

// ==================================================
// PHASE 7 — Target & Performance
// ==================================================

model Target {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  userId         String?      @db.Uuid
  teamId         String?      @db.Uuid
  metric         TargetMetric
  period         TargetPeriod
  startDate      DateTime     @db.Date
  endDate        DateTime     @db.Date
  targetValue    Float
  achievedValue  Float        @default(0)
  status         TargetStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([organizationId, metric, period])
}

enum TargetMetric {
  REVENUE
  VISITS
  NEW_LEADS
  CONVERSIONS
  ATTENDANCE
  DAR
  ACTIVITIES
}

enum TargetPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TargetStatus {
  ACTIVE
  CLOSED
}

// ==================================================
// PHASE 8 — Notifications
// ==================================================

model Notification {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @db.Uuid
  userId         String             @db.Uuid
  title          String
  message        String
  type           NotificationType
  status         NotificationStatus @default(UNREAD)
  referenceType  String?
  referenceId    String?            @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}

model NotificationTemplate {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @db.Uuid
  name           String           @unique
  subject        String?
  body           String
  type           NotificationType
  variables      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  EMAIL
  SMS
  IN_APP
}

enum NotificationStatus {
  UNREAD
  READ
}

// ==================================================
// PHASE 9 — Tasks, Beat Plans, Calendar
// ==================================================

model Task {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  title          String
  description    String?
  status         String    @default("PENDING")
  dueDate        DateTime?
  referenceType  String?
  referenceId    String?   @db.Uuid

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}

model BeatPlan {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  title          String
  startDate      DateTime
  endDate        DateTime
  status         String    @default("DRAFT")

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}

model CalendarEvent {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  type           String

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}

// ==================================================
// PHASE 10 — Settings
// ==================================================

model WorkflowSettings {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  autoAssign     Boolean   @default(true)
  requireApproval Boolean  @default(true)
  approvalHierarchy Json?  // Configuration of who approves what

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model NotificationPreference {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  userId         String    @db.Uuid
  emailEnabled   Boolean   @default(true)
  smsEnabled     Boolean   @default(false)
  inAppEnabled   Boolean   @default(true)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}

model BusinessRuleConfig {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  ruleKey        String    // e.g. "MAX_LEADS_PER_DAY"
  ruleValue      String    // e.g. "50"
  description    String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, ruleKey])
}
